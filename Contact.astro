---
// src/components/Contact.astro
---./_ApplicationModal.jsx
<section id="contact" class="py-40 bg-white text-black text-center relative overflow-hidden font-['Inter']">
  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <span class="text-[10px] tracking-[0.5em] text-[#FF5F00] uppercase font-black mb-10 block italic font-['Inter']">
      Boutique Partnership Model
    </span>
    <h2 class="text-5xl md:text-8xl font-[900] uppercase italic tracking-tighter mb-12 leading-[0.85] text-black">
      High-Touch Focus.<br/>
      <span class="text-transparent" style="-webkit-text-stroke: 1px #000;">Unrivaled Results.</span>
    </h2>
    
    <a 
      href="https://wa.me/55XXXXXXXXXXX" 
      target="_blank"
      class="inline-block bg-black text-white font-[900] uppercase tracking-[0.2em] px-20 py-8 text-xs hover:bg-[#FF5F00] transition-all duration-700 shadow-2xl cursor-pointer"
    >
      Apply for a Partnership
    </a>
  </div>
</section>