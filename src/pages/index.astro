---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BentoGrid from '../components/BentoGrid.astro';
import Services from '../components/Services.astro';
import AdPlatforms from '../components/AdPlatforms.astro';
import Contact from '../components/Contact.astro';
import WhatsappButton from '../components/WhatsappButton.jsx';
import CookieBanner from '../components/CookieBanner.jsx';
---

<Layout title="VOSK MEDIA | Growth Boutique">
	<main class="bg-black relative">
		<Hero />
		
		<div class="py-12 border-b border-white/5 overflow-hidden select-none">
			<div class="flex animate-marquee font-[900] uppercase text-6xl md:text-8xl opacity-10">
				<span class="mx-8">Retention</span><span class="mx-8">Scale</span><span class="mx-8 italic text-stroke">Data</span>
				<span class="mx-8">Growth</span><span class="mx-8">Conversion</span><span class="mx-8 italic text-stroke">Performance</span>
			</div>
		</div>

        <AdPlatforms />

		<BentoGrid />
        
        <Services />
        
        <Contact />

        <footer class="py-24 flex flex-col items-center bg-black font-['Inter'] px-6 text-center border-t border-white/5 relative overflow-hidden">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-black to-white/10"></div>
            
            <img src="/logo.png" alt="VOSK" class="h-4 opacity-20 mb-10 mt-12" />
            <div class="flex gap-10 mb-12">
                <a href="#" class="group"><img src="/instagram.svg" class="w-5 h-5 invert opacity-30 group-hover:opacity-100 transition-all" /></a>
                <a href="#" class="group"><img src="/linkedin.svg" class="w-5 h-5 invert opacity-30 group-hover:opacity-100 transition-all" /></a>
                <a href="#" class="group"><img src="/facebook.svg" class="w-5 h-5 invert opacity-30 group-hover:opacity-100 transition-all" /></a>
            </div>
            
            <p class="mt-14 text-[9px] uppercase tracking-[0.6em] text-white/30 font-light italic">
                Crafting global scale from Brazil. © 2026 VOSK MEDIA.
            </p>
        </footer>

        <WhatsappButton client:load />
        <CookieBanner client:load />
	</main>
</Layout>

<style>
	@keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
	.animate-marquee { display: flex; width: max-content; animation: marquee 50s linear infinite; }
</style>