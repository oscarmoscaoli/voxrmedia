---
// src/components/AdPlatforms.astro
const platforms = [
  { name: 'TikTok', icon: '/tiktok.svg' },
  { name: 'Pinterest', icon: '/pinterest.svg' },
  { name: 'Meta', icon: '/facebook.svg' }, // Usando o facebook.svg que você já tem
  { name: 'Instagram', icon: '/instagram.svg' },
  { name: 'X', icon: '/x.svg' },
  { name: 'LinkedIn', icon: '/linkedin.svg' }
];
---
<section class="py-24 bg-black border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 text-center">
    <span class="text-[10px] tracking-[0.5em] text-white/30 uppercase font-black mb-12 block italic">
      Multi-Channel Acquisition
    </span>
    
    <div class="flex flex-wrap justify-center items-center gap-12 md:gap-20 opacity-40 grayscale transition-all">
      {platforms.map(platform => (
        <div class="group flex flex-col items-center gap-4">
          <img 
            src={platform.icon} 
            alt={platform.name} 
            class="h-8 md:h-10 w-auto invert hover:opacity-100 transition-opacity duration-500" 
          />
          <span class="text-[8px] tracking-widest uppercase font-bold opacity-0 group-hover:opacity-100 transition-all duration-500">
            {platform.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>