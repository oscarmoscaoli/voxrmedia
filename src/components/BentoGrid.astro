---
import Counter from './Counter.jsx';
---
<section class="py-32 max-w-7xl mx-auto px-6 bg-black">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[340px]">
    
    <div class="md:col-span-8 bg-[#080808] border border-white/5 rounded-2xl p-12 flex flex-col justify-end group overflow-hidden relative transition-all hover:border-white/20">
      <video autoplay muted loop playsinline preload="auto" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:opacity-50 transition-opacity duration-1000 grayscale pointer-events-none">
        <source src="/video-preview.webm" type="video/webm" />
      </video>
      <div class="z-10 relative pointer-events-none">
        <span class="text-[10px] tracking-[0.4em] text-[#FF5F00] uppercase font-bold mb-4 block italic">01 / Creative</span>
        <h3 class="text-5xl md:text-6xl font-[900] italic uppercase leading-[0.9] tracking-tighter text-white">
          High-Retention<br/>Narratives
        </h3>
        <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 mt-4">Narrativas de Alta Retenção</p>
      </div>
    </div>

    <div class="md:col-span-4 bg-white text-black rounded-2xl p-12 flex flex-col justify-between transition-transform duration-500 hover:scale-[1.02]">
      <span class="text-[10px] tracking-[0.4em] uppercase font-black opacity-30 italic">02 / Performance</span>
      <div>
        <h4 class="text-7xl md:text-8xl font-[900] italic tracking-tighter leading-none">
          +<Counter client:visible value={20} suffix="x" />
        </h4>
        <p class="text-[10px] font-black uppercase tracking-widest mt-6">Avg. ROAS for E-commerce</p>
        <p class="text-[8px] font-bold uppercase opacity-30 mt-1 italic">Média de ROAS para E-commerce</p>
      </div>
    </div>

    <div class="md:col-span-12 bg-[#FF5F00] rounded-2xl p-12 md:p-16 flex flex-col md:flex-row items-center justify-between group cursor-pointer transition-all hover:brightness-110">
      <div class="text-center md:text-left">
          <h3 class="text-5xl md:text-8xl font-[900] italic uppercase leading-none text-white tracking-tighter">Ready to Scale?</h3>
          <p class="text-[10px] md:text-xs font-black uppercase tracking-[0.5em] text-black/40 mt-4">Pronto para escalar?</p>
      </div>
      <div class="w-24 h-24 rounded-full border border-white/30 flex items-center justify-center mt-10 md:mt-0 group-hover:bg-white transition-all duration-700">
        <span class="text-5xl text-white group-hover:text-[#FF5F00] group-hover:rotate-45 transition-all">→</span>
      </div>
    </div>

  </div>
</section>